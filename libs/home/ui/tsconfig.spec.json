{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "../../../dist/out-tsc",
        "module": "ESNext",
        "target": "ES2022",
        "types": ["jest", "node"]
    },
    "files": ["src/test-setup.ts"],
    "include": [
      "jest.config.cts",
      "src/**/*.test.ts",
      "src/**/*.spec.ts",
      "src/**/*.d.ts"
    ],
    "angularCompilerOptions": {
      "extendedDiagnostics": {
        "checks": {
          "nullishCoalescingNotNullable": "suppress",
          "optionalChainNotNullable": "suppress"
        }
      }
    }
}
